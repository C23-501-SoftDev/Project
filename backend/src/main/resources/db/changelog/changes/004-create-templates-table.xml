<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-create-templates-table" author="knowledgebase-dev">
        <comment>Создание таблицы шаблонов документов</comment>

        <createTable tableName="templates"
                     remarks="Предустановленные шаблоны документов для разных ролей">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_templates" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)" remarks="Название шаблона">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_templates_name"/>
            </column>
            <column name="description" type="TEXT" remarks="Описание шаблона"/>
            <column name="content" type="TEXT" remarks="Содержимое шаблона в Markdown">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)"
                    remarks="Роль, для которой доступен шаблон">
                <constraints nullable="false"/>
            </column>
            <column name="is_system" type="BOOLEAN" defaultValueBoolean="true"
                    remarks="Системные шаблоны нельзя изменять (MVP)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            ALTER TABLE templates
                ADD CONSTRAINT chk_templates_role
                    CHECK (role IN ('Admin', 'Editor', 'Reader', 'Developer', 'Analyst'));
        </sql>

        <createIndex tableName="templates" indexName="idx_templates_role">
            <column name="role"/>
        </createIndex>

        <!-- Триггер для templates -->
        <sql>
            CREATE TRIGGER trigger_templates_updated_at
                BEFORE UPDATE ON templates
                FOR EACH ROW
                EXECUTE FUNCTION update_updated_at_column();
        </sql>

        <rollback>
            <sql>DROP TRIGGER IF EXISTS trigger_templates_updated_at ON templates;</sql>
            <dropTable tableName="templates"/>
        </rollback>
    </changeSet>

</databaseChangeLog>