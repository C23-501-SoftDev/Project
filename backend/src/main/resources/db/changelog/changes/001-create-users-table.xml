<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-users-table" author="knowledgebase-dev">
        <comment>Создание таблицы пользователей и функции обновления updated_at</comment>

        <!-- Создаем функцию для автоматического обновления updated_at -->
        <sql splitStatements="false">
            CREATE OR REPLACE FUNCTION update_updated_at_column()
            RETURNS TRIGGER AS $$
            BEGIN
                NEW.updated_at = CURRENT_TIMESTAMP;
                RETURN NEW;
            END;
            $$ LANGUAGE plpgsql;
        </sql>

        <createTable tableName="users" remarks="Зарегистрированные пользователи системы">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_users" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(100)" remarks="Логин для входа в систему">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_login"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)" remarks="Хеш пароля BCrypt">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)" remarks="Адрес электронной почты">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_email"/>
            </column>
            <column name="role" type="VARCHAR(20)" defaultValue="Reader"
                    remarks="Глобальная роль: Admin, Editor, Reader">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- CHECK constraint на допустимые значения роли -->
        <sql>
            ALTER TABLE users
                ADD CONSTRAINT chk_users_role
                    CHECK (role IN ('Admin', 'Editor', 'Reader'));
        </sql>

        <!-- Триггер для users -->
        <sql>
            CREATE TRIGGER trigger_users_updated_at
                BEFORE UPDATE ON users
                FOR EACH ROW
                EXECUTE FUNCTION update_updated_at_column();
        </sql>

        <rollback>
            <sql>DROP TRIGGER IF EXISTS trigger_users_updated_at ON users;</sql>
            <sql>DROP FUNCTION IF EXISTS update_updated_at_column();</sql>
            <dropTable tableName="users"/>
        </rollback>
    </changeSet>

</databaseChangeLog>